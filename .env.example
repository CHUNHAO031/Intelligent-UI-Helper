# xAI Grok API Key（必填）
XAI_API_KEY=your_xai_api_key_here

# 可选：模型（默认 grok-4.20-beta-latest-non-reasoning）
XAI_MODEL=grok-4.20-beta-latest-non-reasoning

# 可选：API Base URL（默认 https://api.x.ai/v1）
XAI_BASE_URL=https://api.x.ai/v1

# 可选：服务端端口（默认 8787）
PORT=8787

# 可选：是否托管构建后的前端静态文件（默认开启；设为 0 仅跑 API）
SERVE_STATIC=1

